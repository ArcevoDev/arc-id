{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@/prisma-client": ["./prisma/generated", "./prisma/generated/index"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/app/**"]
}
