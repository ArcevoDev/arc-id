{
  "name": "arc-id",
  "version": "0.1.0",
  "description": "Sovereign Decentralized Identity (DID) & Access Management Engine powering the ArcevoCirqle ecosystem. Built on Fastify, Prisma, and WebAuthn/Passkeys with native support for OIDC, SD-JWT Verifiable Credentials, and multi-tenant policy structures.",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev:web": "next dev",
    "build:web": "next build",
    "start:web": "next start",
    "dev:api": "tsx watch --tsconfig tsconfig.api.json src/api/server.ts",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist/api/server.js",
    "dev": "pnpm run dev:all",
    "dev:all": "concurrently \"pnpm run dev:web\" \"pnpm run dev:api\" ",
    "mail:preview": "email dev --dir src/core/mail/templates",
    "lint": "eslint",
    "format": "prettier --write .",
    "postinstall": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:run": "npx prisma validate && pnpm prisma:format && pnpm prisma:generate && pnpm prisma:migrate",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/under-pressure": "^9.0.3",
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@sd-jwt/core": "^0.19.0",
    "@sd-jwt/crypto-nodejs": "^0.19.0",
    "@simplewebauthn/server": "^13.3.0",
    "@upstash/redis": "^1.38.0",
    "argon2": "^0.44.0",
    "date-fns": "^4.3.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "otplib": "^13.4.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-email/ui": "6.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "react-email": "^6.5.0",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f"
}
