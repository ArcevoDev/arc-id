{
  "name": "arc-id",
  "version": "0.0.1",
  "description": "Sovereign Decentralized Identity (DID) & Access Management Engine powering the ArcevoCirqle ecosystem. Built on Fastify, Prisma, and WebAuthn/Passkeys with native support for OIDC, SD-JWT Verifiable Credentials, and multi-tenant policy structures.",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev:web": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build:web": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start:web": "next start",
    "dev:api": "tsx watch --tsconfig tsconfig.api.json src/api/server/start-server.ts",
    "dev:workers": "tsx watch --tsconfig tsconfig.api.json src/api/server/start-workers.ts",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist/api/server/start-server.js",
    "start:workers": "node dist/api/server/start-workers.js",
    "dev": "pnpm run dev:all",
    "dev:all": "concurrently \"pnpm run dev:web\" \"pnpm run dev:api\" \"pnpm run dev:workers\"",
    "mail:preview": "email dev --dir src/core/mail/templates",
    "lint": "eslint",
    "format": "prettier --write .",
    "postinstall": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:run": "npx prisma validate && pnpm prisma:format && pnpm prisma:migrate && pnpm prisma:generate",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/under-pressure": "^9.0.3",
    "@getbrevo/brevo": "^5.0.4",
    "@hookform/resolvers": "^5.4.0",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.12",
    "@sd-jwt/core": "^0.19.0",
    "@sd-jwt/sd-jwt-vc": "^0.20.0",
    "@sd-jwt/types": "^0.19.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@upstash/redis": "^1.38.0",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^6.2.3",
    "lucide-react": "0.468.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "otplib": "^13.4.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-email/ui": "6.5.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "react-email": "^6.5.0",
    "tailwindcss": "^4.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.5.1"
}
